# ============================================
# DALAAL CONNECT - DOCKER ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in your values
# Usage: cp .env.docker .env

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_PASSWORD=1234
DB_NAME=Dalaal-App
DB_USER=postgres

# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=3002
NODE_ENV=development
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:3002

# ============================================
# SMTP CONFIGURATION (Email Service)
# ============================================
# Use App Password for Gmail (16 chars, no spaces)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Dalaal Connect <your_email@gmail.com>
APP_NAME=Dalaal Connect

# ============================================
# STREAM API (Video/Chat)
# ============================================
# Get from: https://getstream.io/dashboard/
STREAM_APP_ID=your_stream_app_id
STREAM_API_KEY=your_stream_api_key
STREAM_SECRET_KEY=your_stream_secret_key

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,video/mp4,application/pdf

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ORIGIN=http://localhost,http://localhost:8081

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100