# API Configuration
# Choose ONE based on your device:
#
#   iOS Simulator:       EXPO_PUBLIC_API_URL=http://localhost:3002/api
#   Android Emulator:    EXPO_PUBLIC_API_URL=http://10.0.2.2:3002/api
#   Physical Device:     EXPO_PUBLIC_API_URL=http://[YOUR_COMPUTER_IP]:3002/api
#
# To find YOUR_COMPUTER_IP:
#   - On Windows: Open Command Prompt and type: ipconfig
#   - Look for "IPv4 Address" (usually starts with 192.168.x.x or 10.x.x.x)
#
# EXAMPLE (replace with your actual IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3002/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.100:3002/chat

# iOS Simulator (uncomment this if using Xcode simulator):
# EXPO_PUBLIC_API_URL=http://localhost:3002/api
# EXPO_PUBLIC_SOCKET_URL=http://localhost:3002/chat

# Android Emulator (uncomment this if using Android emulator):
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3002/api
# EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:3002/chat

# Physical Device (uncomment and replace with your computer's IP - OR LEAVE COMMENTED FOR AUTO-DETECTION!):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3002/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.100:3002/chat

# NOTE: Leave all above commented out for AUTO-DETECTION to work on ANY network!

