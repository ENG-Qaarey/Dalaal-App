# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:8081

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dalaal_prime

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Redis (Optional - for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@dalaal.com
SENDGRID_FROM_NAME=Dalaal Prime

# SMS (Africa's Talking)
AFRICASTALKING_USERNAME=your-username
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_FROM=your-sender-id

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Mobile Money Providers
EVC_PLUS_API_KEY=your-evc-plus-api-key
EVC_PLUS_MERCHANT_ID=your-merchant-id
ZAAD_API_KEY=your-zaad-api-key
ZAAD_MERCHANT_ID=your-merchant-id
SAHAL_API_KEY=your-sahal-api-key
SAHAL_MERCHANT_ID=your-merchant-id

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# Maps
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Payment
PLATFORM_FEE_PERCENTAGE=2.5
ESCROW_COMMISSION_PERCENTAGE=5

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Verification AI (Optional)
OPENAI_API_KEY=your-openai-api-key
